# =============================================================================
# POS & Inventory — environment variables
# Copy to `.env` for local dev. In Vercel, add each as a Project Environment Variable.
# =============================================================================

# --- Supabase (required) ----------------------------------------------------
# Get these from your Supabase project: Settings → API.
# The publishable key is the "anon" key — safe to expose to the browser.
# NEVER put SUPABASE_SERVICE_ROLE_KEY here or in any VITE_* variable.
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Mirror for server-side rendering (TanStack Start server functions).
# Use the SAME values as the VITE_* keys above.
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-only. Used by privileged server functions (admin client). DO NOT prefix with VITE_.
# Leave blank if you are not running any admin/maintenance server functions.
SUPABASE_SERVICE_ROLE_KEY=""

# --- App branding defaults (optional) --------------------------------------
# Most branding lives in the `settings` database row and is editable from the
# Settings page. These env values are used only as fallbacks before the first
# settings row is loaded.
VITE_APP_NAME="POS & Inventory"
VITE_APP_ENV="production"          # development | staging | production
VITE_DEFAULT_CURRENCY="PKR"
VITE_DEFAULT_CURRENCY_SYMBOL="Rs."
